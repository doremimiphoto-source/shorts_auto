# ==================== Shorts Auto Pipeline 환경변수 예시 ====================
# 이 파일을 복사하여 `.env`로 저장한 뒤 실제 키 값을 채운다.
# `.env`는 절대 git에 커밋하지 않는다 (`.gitignore`에 등록됨).
# ============================================================================

# ---------- LLM (FR-2) ----------
# Gemini API: https://aistudio.google.com/  → "Get API key"
# 무료 한도: RPM 15 / RPD 1,500 (Gemini 2.5 Flash)
GEMINI_API_KEY=

# Groq API: https://console.groq.com/  → API Keys
# 무료 한도: RPM 30 (Llama 3.1 8B Instant)
GROQ_API_KEY=

# Ollama (CPU 비상 폴백, 로컬). 기본 endpoint 그대로 두면 됨.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2:2b

# ---------- TTS (FR-3) ----------
# Piper 바이너리/모델 경로. 절대경로 또는 프로젝트 상대경로.
PIPER_BIN_PATH=piper
PIPER_VOICE_MODEL=models/piper/ko_KR-kss-medium.onnx
PIPER_VOICE_CONFIG=models/piper/ko_KR-kss-medium.onnx.json

# ---------- 에셋 (FR-5) ----------
# Pexels: https://www.pexels.com/api/  → 무료 200req/h
PEXELS_API_KEY=
# Pixabay: https://pixabay.com/api/docs/  → 무료 100req/h
PIXABAY_API_KEY=

# ---------- 업로드 (FR-6) ----------
# Google Cloud Console에서 다운로드한 OAuth 클라이언트 JSON 경로
YOUTUBE_CLIENT_SECRET_PATH=credentials/client_secret.json
# 첫 OAuth 인증 후 자동 저장될 토큰 파일 경로
YOUTUBE_TOKEN_PATH=credentials/token.json
# 채널 ID는 채널 생성 후 입력 (선택; 단일 채널이면 비워둬도 됨)
YOUTUBE_CHANNEL_ID=

# ---------- 알림 (FR-8.4) ----------
# Discord Webhook URL (선택). 비워두면 알림 비활성화.
DISCORD_WEBHOOK_URL=

# ---------- 운영 옵션 ----------
LOG_LEVEL=INFO
TIMEZONE=Asia/Seoul
# 환경 식별: development / production
APP_ENV=development
